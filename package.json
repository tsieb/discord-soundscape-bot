{
  "name": "discord-soundscape-bot",
  "version": "1.0.0",
  "description": "A lightweight Discord bot that plays random ambient sounds in voice channels.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "deploy": "tsx src/deploy-commands.ts"
  },
  "keywords": [
    "discord",
    "bot",
    "soundscape",
    "typescript"
  ],
  "author": "trent",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.1",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "prism-media": "^1.3.5",
    "sodium-native": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
