# Required: Discord bot token from Developer Portal -> Bot tab
DISCORD_TOKEN=your-discord-bot-token

# Required: Discord application ID from Developer Portal -> General Information
CLIENT_ID=123456789012345678

# Optional: single guild ID for instant command deployment during development
# Leave blank to deploy global commands (can take up to 1 hour to propagate)
GUILD_ID=

# Optional: default minimum seconds between random sounds (must be > 0)
DEFAULT_MIN_INTERVAL=30

# Optional: default maximum seconds between random sounds (must be >= min)
DEFAULT_MAX_INTERVAL=300

# Optional: default playback volume from 0.0 to 1.0
DEFAULT_VOLUME=0.5

# Optional: logging level (info or debug)
LOG_LEVEL=info

# Optional: directory containing sounds
SOUNDS_DIR=./sounds

# Optional: directory for runtime data (for example data/config.json)
DATA_DIR=./data
